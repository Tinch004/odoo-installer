{
  "name": "odoo-manager",
  "version": "1.0.0",
  "description": "Odoo Manager — Desktop app for managing Odoo instances, modules, and services",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build": "npm run build:renderer && npm run build:main && npm run build:preload",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "start": "electron .",
    "dist": "npm run build && electron-builder",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:win": "npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.odoo-manager.app",
    "productName": "Odoo Manager",
    "files": [
      "dist/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Development",
      "icon": "resources/icon.png"
    },
    "win": {
      "target": ["nsis"],
      "icon": "resources/icon.ico"
    }
  },
  "keywords": ["odoo", "manager", "electron", "modules"],
  "author": "",
  "license": "MIT"
}
